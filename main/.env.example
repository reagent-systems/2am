# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key — used by all agents and the Claude Agent SDK
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: Messaging connectors ────────────────────────────────────────────

# Telegram bot token — see messaging/telegram/README.md
# TELEGRAM_BOT_TOKEN=123456789:ABCdef...

# Discord bot token + channel to post into — see messaging/discord/README.md
# DISCORD_BOT_TOKEN=your-token-here
# DISCORD_CHANNEL_ID=123456789012345678

# ── Optional: Web Search ───────────────────────────────────────────────────────

# SearXNG instance URL — required only if using the searxng tool
# Self-host: https://docs.searxng.org/admin/installation.html
# SEARXNG_URL=http://localhost:8080

# ── Optional: Archive ─────────────────────────────────────────────────────────

# Path to the archive data directory (default: ./archive/data)
# ARCHIVE_PATH=./archive/data

# ── Optional: Logging ─────────────────────────────────────────────────────────

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# LOG_LEVEL=INFO
